<div class="flex justify-center">
    <div class="w-full boder bg-black p-4 sm:px-16 sm:px-8">
      <div class="min-h-screen flex">
<% if flash[:alert] %>
  <div class="text-white m-2 p-2"><%= flash[:alert] %></div>
<% end %>          
        <main class="flex-1 p-2 sm:p-10">
          <div class="mb-8">
            <div class="flex items-center justify-between">
              <p class="text-lg sm:text-4xl font-bold text-gray-500">Xin chào <span class="text-gray-500"><%= @current_user.name %></span> 👋</p>
              <div class="p-1 sm:p-2">
                <%= button_to "Đăng xuất",
                    logout_path,
                    method: :delete,
                    class: "w-full text-left p-2 sm:p-3 rounded-lg hover:bg-red-600 bg-red-500" %>
              </div>
            </div>
            <p class="text-md sm:text-4xl text-gray-400 mt-1 sm:mt-2">
              Quản lý toàn bộ website nội thất Mộc Phương
            </p>
          </div>
              
          <!-- CARDS -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              
            <% dashboard_items = [
              ["📦", "Đơn hàng", admin_orders_path],
              ["💬", "Yêu cầu tư vấn", admin_requests_path],

              ["🪑", "Sản phẩm", admin_products_path],
              ["📂", "Danh mục", admin_categories_path],
              

              ["🖼️", "Trang chủ", edit_admin_introduction_path],
              ["💼", "Dự án", admin_project_informations_path],
              ["📊", "Trang bìa dự án", admin_project_information_infors_path],
              ["🏠", "Trang trí nội thất", admin_decorations_path],
              ["📞", "Liên hệ", edit_admin_contact_path],
              ["🛋️", "Thiết bị và phụ kiện", admin_accessories_path],
              ["🏭", "Xưởng sản xuất", edit_admin_factory_path],
              ["🏢", "Văn phòng thiết kế", edit_admin_design_office_path],
              ["🔥", "Showroom", edit_admin_showroom_path],
              

              ["👤", "Quản trị viên", admin_users_path],
              ["🏷️", "Slogan & Logo", edit_admin_slogan_path],
              ["🎨", "Màu giao diện", edit_admin_color_path],
            ] %>
              
            <% dashboard_items.each do |icon, title, path| %>
              <%= link_to path, class: "bg-white/70 backdrop-blur-md rounded-2xl p-4 sm:p-6 shadow hover:bg-white/80 transition group" do %>
              <div class="text-4xl mb-4 flex justify-center transform transition-transform group-hover:scale-110">
                  <%= icon %>
                </div>

                <h2 class="text-xl font-semibold text-gray-800">
                  <%= title %>
                </h2>
                <p class="text-gray-500 text-sm mt-2">
                  Quản lý <%= title.downcase %>
                </p>
              <% end %>
            <% end %>
                
          </div>
        </main>
                
      </div>
                
    </div>
</div>



<canvas id="meteor-canvas"></canvas>


<script>
(() => {
  const canvas = document.getElementById("meteor-canvas");
  const ctx = canvas.getContext("2d");

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  const stars = [];
  const STAR_COUNT = 120;

  function initStars() {
    stars.length = 0;
    for (let i = 0; i < STAR_COUNT; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        r: Math.random() * 1.5 + 0.5,
        o: Math.random(),
        speed: Math.random() * 0.02 + 0.005
      });
    }
  }

  initStars();

  function drawStars() {
    stars.forEach(s => {
      s.o += s.speed;
      if (s.o > 1 || s.o < 0) s.speed *= -1;

      ctx.beginPath();
      ctx.fillStyle = `rgba(255,255,255,${s.o})`;
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    });
  }

  class Meteor {
  constructor() {
    this.reset();
  }

  reset() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * -canvas.height;
    this.len = Math.random() * 130 + 20;
    this.speed = Math.random() * 4 + 2;
    this.life = 0;
    this.maxLife = Math.random() * 80 + 80;
  }

  draw() {
    const alpha = Math.min(this.life / 20, (this.maxLife - this.life) / 20);

    ctx.beginPath();
    ctx.strokeStyle = `rgba(255,255,255,${alpha})`;
    ctx.lineWidth = 1.5;
    ctx.moveTo(this.x, this.y);
    ctx.lineTo(this.x - this.len, this.y + this.len);
    ctx.stroke();
  }

  update() {
    this.x -= this.speed;
    this.y += this.speed;
    this.life++;

    if (
      this.life > this.maxLife ||
      this.y > canvas.height ||
      this.x < -this.len
    ) {
      this.reset();
    }
  }
}


  const meteors = Array.from({ length: 10 }, () => new Meteor());

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    drawStars();

    meteors.forEach(m => {
      m.update();
      m.draw();
    });

    requestAnimationFrame(animate);
  }

  animate();
})();
</script>
