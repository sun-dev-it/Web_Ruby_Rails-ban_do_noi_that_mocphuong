<div class="flex justify-center min-h-screen bg-gray-50 py-8">
  <div class="w-[90%] sm:w-[70%] lg:w-[50%] bg-white rounded-2xl shadow-md p-6 sm:p-10">

    <h1 class="text-center text-2xl sm:text-4xl font-bold text-gray-800 mb-8">
      Xin chào <%= @user.name %>!
    </h1>

    <div class="space-y-4">

      <%= link_to cart_path,
          class: "flex items-center justify-between p-4 rounded-xl border border-gray-200 hover:border-black hover:bg-gray-50 transition-all duration-300" do %>

        <span class="text-lg font-medium text-gray-800">
          Giỏ hàng của bạn
        </span>

        <svg xmlns="http://www.w3.org/2000/svg"
             fill="none"
             viewBox="0 0 24 24"
             stroke-width="2"
             stroke="currentColor"
             class="size-5">
          <path stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7" />
        </svg>

      <% end %>

      <%= link_to orders_path,
          class: "flex items-center justify-between p-4 rounded-xl border border-gray-200 hover:border-black hover:bg-gray-50 transition-all duration-300" do %>

        <span class="text-lg font-medium text-gray-800">
          Đơn hàng của bạn
        </span>

        <svg xmlns="http://www.w3.org/2000/svg"
             fill="none"
             viewBox="0 0 24 24"
             stroke-width="2"
             stroke="currentColor"
             class="size-5">
          <path stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7" />
        </svg>

      <% end %>

    </div>

    <div class="flex justify-end mt-10">
      <%= button_to logout_path,
            method: :delete,
            class: "text-gray-600 hover:text-red-500 underline underline-offset-4 transition-colors duration-300" do %>
        Đăng xuất
      <% end %>
    </div>

  </div>
</div>