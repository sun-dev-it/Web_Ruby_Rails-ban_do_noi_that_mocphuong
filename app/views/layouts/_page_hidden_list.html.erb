  <div class="relative z-[999999] border-r border-gray-300">

      <div id="PageHidden" class="h-screen slide-left flex fixed inset-0 w-[70%] md:w-[30%] hidden">
        <div class="flex fixed flex-col h-screen w-full z-[999999] slide-left left-0 p-2 sm:p-6 bg-white text-black font-semibold font-sans space-y-3 custom-scroll overflow-y-auto">
          
          <%= header_hidden_link "TRANG CHỦ", root_path %>

          
          <hr class="border-gray-300" />

          <div class="flex items-center justify-between">
            <%= header_hidden_link "SẢN PHẨM", categories_path %>

            <div id="ButtonListCatalogHidden">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </div>

          <div id="ListCatalogHidden" class="hidden">
            <div class="flex flex-col slide-down mt-[-5px] space-y-3 ml-6">  
              <% @categories.each do |category| %>
                <%= link_to category_path(category) do %>
                  <div class="text-gray-500"><%= category.name %></div>
                <% end %>
              <% end %>   
            </div>     
          </div>

          <hr class="border-gray-300" />

          

          <div class="flex items-center justify-between">
            <%= header_hidden_link "DỰ ÁN", project_informations_path %>
          </div>

          <hr class="border-gray-300" />

          <div class="flex items-center justify-between">
            <%= header_hidden_link "TRANG TRÍ NỘI THẤT", decorations_path %>

            <div id="ButtonListDecorationHidden">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </div>

 
          <div id="ListDecorationHidden" class="hidden">
            <div class="flex flex-col slide-down mt-[-5px] space-y-3 ml-6">
              <% @decorations.each do |decoration| %>
                <div class="text-gray-500"><%= link_to decoration.name, decoration_path(decoration) %></div>
              <% end %>      
            </div>
          </div>

          <hr class="border-gray-300" />

          <%= header_hidden_link "VỀ CHÚNG TÔI", about_us_path %>

          <hr class="border-gray-300" />

          <div class="flex items-center justify-between">
            <%= header_hidden_link "THIẾT BỊ VÀ PHỤ KIỆN", accessories_path %>
          </div>
        </div>
      </div>
  </div>